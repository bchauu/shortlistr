# Copy this file to `backend/.env` for local development.
# Do not commit `backend/.env` (it contains secrets).

# OpenAI (optional; backend falls back to heuristics if missing)
OPENAI_API_KEY=xxxx
OPENAI_MODEL=gpt-4o-mini

# MongoDB (required for accounts + sync)
MONGODB_URI=mongodb+srv://USER:PASSWORD@YOUR_CLUSTER.mongodb.net/shortlistr?retryWrites=true&w=majority
MONGODB_DB=shortlistr

# Auth (required)
JWT_SECRET=xxxx
JWT_EXPIRES_DAYS=30

# Server
PORT=8787
RATE_LIMIT_PER_MINUTE=60

# Optional: restrict CORS for non-extension clients (comma-separated)
# CORS_ORIGINS=https://your-website.com
